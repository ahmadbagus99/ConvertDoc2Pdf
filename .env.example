# Copy file ini menjadi .env dan isi nilainya
# cp .env.example .env

# --- Wajib diisi di production ---
BASICAUTH_USERNAME=your_username_here
BASICAUTH_PASSWORD=your_strong_password_here

# --- Opsional (ada default-nya) ---
PORT=8080

# Jumlah konversi yang berjalan bersamaan (sesuaikan dengan jumlah vCPU)
CONVERSION_MAX_CONCURRENCY=2

# Maksimal request yang mengantri
CONVERSION_MAX_QUEUE_SIZE=20

# Timeout menunggu di antrian (detik)
CONVERSION_QUEUE_TIMEOUT_SECONDS=30
